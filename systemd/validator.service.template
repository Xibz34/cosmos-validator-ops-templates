[Unit]
Description=Cosmos Validator Node
After=network-online.target
Wants=network-online.target

[Service]
User=validator
ExecStart=/usr/local/bin/<BINARY> start --home /home/validator/.<CHAIN>
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

# Optional hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target